<Window x:Class="Talisman.PomodoroTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="260">
    <Border Background="#EE202020" CornerRadius="6" Padding="8" BorderBrush="#40FFFFFF" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding PhaseLabel}" Foreground="#FFAAAAAA" FontSize="10" />
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock Text="{Binding TimerText}" Foreground="{Binding TimerBrush}"
                           FontFamily="Consolas" FontSize="18" MinWidth="62" VerticalAlignment="Top" />
                <TextBlock Text="{Binding CurrentTaskTitle}" Foreground="White" FontSize="14"
                           TextWrapping="Wrap" Margin="8,0,0,0" Width="170" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Done" Click="DoneClicked" Width="70" />
                <Button Content="Defer" Click="DeferClicked" Width="70" Margin="8,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
