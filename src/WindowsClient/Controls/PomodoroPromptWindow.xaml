<Window x:Class="Talisman.PomodoroPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="260">
    <Border Background="#EE202020" CornerRadius="6" Padding="12" BorderBrush="#40FFFFFF" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="MessageText" Foreground="White" TextWrapping="Wrap" FontSize="13" />
            <Button Content="Start" Click="StartClicked" Width="90" HorizontalAlignment="Right" Margin="0,12,0,0" />
        </StackPanel>
    </Border>
</Window>
